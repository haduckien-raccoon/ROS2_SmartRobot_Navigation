<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="ydlidar_robot_bringup">

  <!-- Constants -->
  <xacro:property name="PI" value="3.14159265359"/>
  <xacro:property name="base_mass" value="5.0"/>
  <xacro:property name="wheel_mass" value="0.5"/>
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width" value="0.04"/>
  <xacro:property name="wheel_separation" value="0.16"/>
  <xacro:property name="base_length" value="0.25"/>
  <xacro:property name="base_width" value="0.20"/>
  <xacro:property name="base_height" value="0.15"/>

  <!-- Base Link -->
  <link name="base_link">
    <inertial>
      <mass value="${base_mass}"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.02"/>
    </inertial>
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
  </link>

  <!-- Wheel Macro -->
  <xacro:macro name="wheel" params="name x_pos y_pos">
    <link name="${name}_link">
      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
        <material name="black">
          <color rgba="0 0 0 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
      </collision>
    </link>

    <joint name="${name}_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="${x_pos} ${y_pos} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="10" velocity="5" lower="-${PI}" upper="${PI}"/>
      <dynamics damping="0.1"/>
    </joint>
  </xacro:macro>

  <!-- 4 Wheels -->
  <xacro:wheel name="wheel_front_left" x_pos="${base_length/2}" y_pos="${wheel_separation/2}"/>
  <xacro:wheel name="wheel_front_right" x_pos="${base_length/2}" y_pos="${-wheel_separation/2}"/>
  <xacro:wheel name="wheel_rear_left" x_pos="${-base_length/2}" y_pos="${wheel_separation/2}"/>
  <xacro:wheel name="wheel_rear_right" x_pos="${-base_length/2}" y_pos="${-wheel_separation/2}"/>

  <!-- Laser/LIDAR Frame -->
  <link name="laser_frame">
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0.12 0 0.3" rpy="0 0 0"/>
  </joint>

  <!-- Camera Frame (cho object detection) -->
  <link name="camera_frame">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="green">
        <color rgba="0 1 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_frame"/>
    <origin xyz="0.12 0 0.25" rpy="0 0.2 0"/>
  </joint>

  <!-- Servo Frame (n?u dùng) -->
  <link name="servo_link"/>
  <joint name="servo_joint" type="revolute">
    <parent link="base_link"/>
    <child link="servo_link"/>
    <origin xyz="0.1 0 0.15" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit effort="5" velocity="1.57" lower="-1.57" upper="1.57"/>
  </joint>

</robot>
