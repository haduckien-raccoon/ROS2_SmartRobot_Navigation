<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <contributor><author>Gemini</author><authoring_tool>Hand-coded</authoring_tool></contributor>
    <unit name="meter" meter="1"/><up_axis>Z_UP</up_axis>
  </asset>

  <library_effects>
    <effect id="Material_005-effect">
      <profile_COMMON>
        <technique sid="common">
          <phong>
            <diffuse><color>0 0.3 0.3 1</color></diffuse>
            <specular><color>0.5 0.5 0.5 1</color></specular>
            <shininess><float>50</float></shininess>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>

  <library_materials>
    <material id="Material_005-material"><instance_effect url="#Material_005-effect"/></material>
  </library_materials>

  <library_geometries>
    <geometry id="L-mesh" name="Letter_L">
      <mesh>
        <source id="L-positions">
          <float_array id="L-positions-array" count="21">
            -0.3 -1.0 0   -0.1 -1.0 0   -0.1  0.8 0   -0.3  0.8 0   0.6 -1.0 0   0.6 -0.8 0   -0.1 -0.8 0   </float_array>
          <technique_common>
            <accessor source="#L-positions-array" count="7" stride="3">
              <param name="X" type="float"/><param name="Y" type="float"/><param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>

        <source id="L-normals">
          <float_array id="L-normals-array" count="3">0 0 1</float_array>
          <technique_common><accessor source="#L-normals-array" count="1" stride="3"/></technique_common>
        </source>

        <vertices id="L-vertices"><input semantic="POSITION" source="#L-positions"/></vertices>

        <triangles material="Material_005-material" count="4">
          <input semantic="VERTEX" source="#L-vertices" offset="0"/>
          <input semantic="NORMAL" source="#L-normals" offset="1"/>
          <p>
            0 0 1 0 2 0   0 0 2 0 3 0
            1 0 4 0 5 0   1 0 5 0 6 0
          </p>
        </triangles>
      </mesh>
    </geometry>
  </library_geometries>

  <library_visual_scenes>
    <visual_scene id="Scene">
      <node id="L_Node">
        <instance_geometry url="#L-mesh">
          <bind_material>
            <technique_common>
              <instance_material symbol="Material_005-material" target="#Material_005-material"/>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene><instance_visual_scene url="#Scene"/></scene>
</COLLADA>