<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <contributor>
      <author>Blender User</author>
      <authoring_tool>Blender 2.79</authoring_tool>
    </contributor>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>

  <library_effects>
    <effect id="Material_005-effect">
      <profile_COMMON>
        <technique sid="common">
          <phong>
            <diffuse>
              <color>0 0.3 0.3 1</color>
            </diffuse>
            <specular>
              <color>0.5 0.5 0.5 1</color>
            </specular>
            <shininess>
              <float>50</float>
            </shininess>
          </phong>
        </technique>
      </profile_COMMON>
    </effect>
  </library_effects>

  <library_materials>
    <material id="Material_005-material">
      <instance_effect url="#Material_005-effect"/>
    </material>
  </library_materials>

  <library_geometries>
    <geometry id="I-mesh" name="Letter_I">
      <mesh>

        <!-- I harfi: tek dikdörtgen (L ile AYNI yapı) -->
        <source id="I-positions">
          <float_array id="I-positions-array" count="12">
            -0.1 -1.0 0
             0.1 -1.0 0
             0.1  0.8 0
            -0.1  0.8 0
          </float_array>
          <technique_common>
            <accessor source="#I-positions-array" count="4" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>

        <source id="I-normals">
          <float_array id="I-normals-array" count="3">0 0 1</float_array>
          <technique_common>
            <accessor source="#I-normals-array" count="1" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>

        <vertices id="I-vertices">
          <input semantic="POSITION" source="#I-positions"/>
        </vertices>

        <!-- AYNI triangle mantığı -->
        <triangles material="Material_005-material" count="2">
          <input semantic="VERTEX" source="#I-vertices" offset="0"/>
          <input semantic="NORMAL" source="#I-normals" offset="1"/>
          <p>
            0 0 1 0 2 0
            0 0 2 0 3 0
          </p>
        </triangles>

      </mesh>
    </geometry>
  </library_geometries>

  <library_visual_scenes>
    <visual_scene id="Scene">
      <node id="I_Node">
        <instance_geometry url="#I-mesh">
          <bind_material>
            <technique_common>
              <instance_material symbol="Material_005-material" target="#Material_005-material"/>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
    </visual_scene>
  </library_visual_scenes>

  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>
